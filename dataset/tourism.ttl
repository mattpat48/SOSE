    rdfs:comment "Historic basilica in Venice, iconic landmark and UNESCO World Heritage site" ;
    ex:hasCategory ex:Museum ;
    ex:belongsToLocation ex:Venice ;
    ex:hasAccessibility ex:PartiallyWheelchairAccessible ;
    ex:hasSustainability ex:Sustainable ;
    ex:hasCrowdingLevel ex:High ;
    ex:hasRating 4.8 ;
    ex:ethicalRating 4.2 ;
    prov:wasAttributedTo ex:LinkedOpenData ;
    ex:lastUpdatedOn "2024-05-15T10:30:00Z"^^xsd:dateTime .

